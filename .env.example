# Copiar a .env y completar. NUNCA commitear el .env real.

# MongoDB. Incluir el nombre de la base en la ruta (…/soporte) — obligatorio,
# database.py usa get_default_database().
# Local:
DATABASE_URL=mongodb://localhost:27017/soporte
# Atlas (producción) — ejemplo:
# DATABASE_URL=mongodb+srv://USER:PASS@cluster0.xxxxx.mongodb.net/soporte?appName=Cluster0

COLECCION=colecciontest0

# JWT — usar un valor aleatorio largo en producción (ej: openssl rand -hex 32)
SECRET_KEY=dev-secret-change-me
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
